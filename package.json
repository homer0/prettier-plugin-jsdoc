{
  "name": "@homer0/prettier-plugin-jsdoc",
  "description": "A Prettier plugin to format JSDoc blocks",
  "version": "11.1.0",
  "repository": "homer0/prettier-plugin-jsdoc",
  "author": "Leonardo Apiwan (@homer0) <me@homer0.com>",
  "license": "MIT",
  "packageManager": "pnpm@11.1.2",
  "keywords": [
    "jsdoc",
    "prettier",
    "comments",
    "documentation",
    "javascript"
  ],
  "type": "module",
  "main": "./src/index.js",
  "module": "./src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./src/*.js": "./src/*.js",
    "./package.json": "./package.json"
  },
  "dependencies": {
    "comment-parser": "^1.4.6",
    "ramda": "0.32.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "@homer0/eslint-plugin": "^14.2.4",
    "@homer0/prettier-config": "^2.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@vitest/coverage-istanbul": "^4.1.6",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "is-ci": "^4.1.0",
    "leasot": "^14.4.0",
    "lint-staged": "^17.0.4",
    "prettier": "^3.8.3",
    "semantic-release": "^25.0.3",
    "vitest": "^4.1.6"
  },
  "peerDependencies": {
    "prettier": "^3.5.3"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/",
    "tag": "latest"
  },
  "engine-strict": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "prepare": "./utils/scripts/prepare",
    "test:unit": "./utils/scripts/test-unit",
    "test:e2e": "./utils/scripts/test-e2e",
    "test": "./utils/scripts/test",
    "lint": "./utils/scripts/lint",
    "lint:all": "./utils/scripts/lint-all",
    "todo": "./utils/scripts/todo"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "lint-staged": {
    "*.js": [
      "eslint",
      "prettier --write"
    ]
  }
}
